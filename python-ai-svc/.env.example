# ─────────────────────────────────────────────────────────────────────────────
# EduTech Python AI Sidecar — Environment Variable Reference
# Copy this file to .env and populate with real values before running locally.
# All variables are read via pydantic-settings (config.py).
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────

# TCP port the uvicorn server listens on
PYTHON_AI_SVC_PORT=8090

# Uvicorn / root logger level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── Model versioning ─────────────────────────────────────────────────────────

# Returned in every response's `modelVersion` field; bumped with each release
MODEL_VERSION=v1.0.0

# ── Model file paths ─────────────────────────────────────────────────────────
# These are optional.  If the files do not exist the service trains a
# lightweight in-memory model on synthetic data at startup.

# Path to a pre-trained Career Predictor pickle file (scikit-learn RandomForest)
CAREER_MODEL_PATH=/app/models/career_model.pkl

# Path to a pre-trained Dropout Risk Model pickle file (scikit-learn Logistic Regression)
RISK_MODEL_PATH=/app/models/risk_model.pkl

# ── Plagiarism / Embeddings ───────────────────────────────────────────────────

# Cosine similarity threshold above which a text pair is flagged as plagiarised
# Range: 0.0 – 1.0  (recommended: 0.85)
PLAGIARISM_SIMILARITY_THRESHOLD=0.85

# SentenceTransformer model name (from Hugging Face Hub or local path)
# Lightweight default: all-MiniLM-L6-v2 (~80 MB)
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# ── Essay grading ────────────────────────────────────────────────────────────

# Minimum word count for an essay to receive a non-zero length adequacy score
ESSAY_MIN_WORDS=20

# Word count treated as "full length" (used only as upper clamp guard)
ESSAY_MAX_WORDS=2000
