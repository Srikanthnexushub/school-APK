# =============================================================================
# EduTech AI Platform — Environment Variable Reference
# =============================================================================
# Copy this file to .env and fill in all values before running locally.
# .env is NEVER committed to git. This file IS committed (no real values here).
# =============================================================================

# -----------------------------------------------------------------------------
# Project version (also set in .mvn/maven.config for Maven builds)
# -----------------------------------------------------------------------------
REVISION=1.0.0-SNAPSHOT

# -----------------------------------------------------------------------------
# PostgreSQL — single instance for local dev, one DB per service
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_ROOT_USER=
POSTGRES_ROOT_PASSWORD=

# Per-service DB credentials
AUTH_SVC_DB_NAME=
AUTH_SVC_DB_USERNAME=
AUTH_SVC_DB_PASSWORD=

PARENT_SVC_DB_NAME=
PARENT_SVC_DB_USERNAME=
PARENT_SVC_DB_PASSWORD=

CENTER_SVC_DB_NAME=
CENTER_SVC_DB_USERNAME=
CENTER_SVC_DB_PASSWORD=

ASSESS_SVC_DB_NAME=
ASSESS_SVC_DB_USERNAME=
ASSESS_SVC_DB_PASSWORD=

PSYCH_SVC_DB_NAME=
PSYCH_SVC_DB_USERNAME=
PSYCH_SVC_DB_PASSWORD=

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Kafka (KRaft — no ZooKeeper)
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# -----------------------------------------------------------------------------
# JWT (RS256 asymmetric keys — generate with scripts/generate-jwt-keys.sh)
# Paths are relative to the running service's working directory
# -----------------------------------------------------------------------------
JWT_PRIVATE_KEY_PATH=
JWT_PUBLIC_KEY_PATH=
JWT_ACCESS_TOKEN_EXPIRY_SECONDS=
JWT_REFRESH_TOKEN_EXPIRY_SECONDS=

# -----------------------------------------------------------------------------
# Argon2id password hashing parameters (OWASP 2024 recommended values)
# -----------------------------------------------------------------------------
ARGON2_MEMORY_COST=
ARGON2_ITERATIONS=
ARGON2_PARALLELISM=
ARGON2_SALT_LENGTH=
ARGON2_HASH_LENGTH=

# -----------------------------------------------------------------------------
# OTP (TOTP — RFC 6238)
# -----------------------------------------------------------------------------
OTP_EXPIRY_SECONDS=
OTP_MAX_ATTEMPTS=
OTP_LENGTH=

# -----------------------------------------------------------------------------
# Google reCAPTCHA v2 (auth-svc) — https://www.google.com/recaptcha/admin
# HCAPTCHA_VERIFY_URL: https://www.google.com/recaptcha/api/siteverify
# Get site key + secret from Google reCAPTCHA admin console > Create new site > reCAPTCHA v2
# -----------------------------------------------------------------------------
HCAPTCHA_VERIFY_URL=https://www.google.com/recaptcha/api/siteverify
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

# -----------------------------------------------------------------------------
# Email (auth-svc / notification)
# -----------------------------------------------------------------------------
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=

# -----------------------------------------------------------------------------
# SMS / Twilio (auth-svc / notification)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# -----------------------------------------------------------------------------
# Firebase (push notifications — parent-svc / center-svc)
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=

# -----------------------------------------------------------------------------
# AI / LLM (ai-gateway-svc)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
OPENAI_API_KEY=
OLLAMA_BASE_URL=
AI_EMBEDDING_MODEL=
AI_EMBEDDING_DIMENSIONS=

# Python FastAPI AI sidecar
PSYCH_AI_SVC_BASE_URL=

# -----------------------------------------------------------------------------
# Service ports
# -----------------------------------------------------------------------------
API_GATEWAY_PORT=8080
AUTH_SVC_PORT=8081
PARENT_SVC_PORT=8082
CENTER_SVC_PORT=8083
ASSESS_SVC_PORT=8084
PSYCH_SVC_PORT=8085
AI_GATEWAY_SVC_PORT=8086
PYTHON_AI_SVC_PORT=8095

# -----------------------------------------------------------------------------
# Observability (OpenTelemetry)
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SAMPLING_PROBABILITY=
LOG_LEVEL_ROOT=
LOG_LEVEL_APP=

# Actuator — comma-separated list e.g. health,info,metrics,prometheus
ACTUATOR_ENDPOINTS=

# -----------------------------------------------------------------------------
# HashiCorp Vault (production — leave blank for local dev)
# -----------------------------------------------------------------------------
VAULT_URI=
VAULT_TOKEN=
VAULT_NAMESPACE=

# -----------------------------------------------------------------------------
# Service application names (used as spring.application.name)
# -----------------------------------------------------------------------------
API_GATEWAY_NAME=
AUTH_SVC_NAME=
PARENT_SVC_NAME=
CENTER_SVC_NAME=
ASSESS_SVC_NAME=
PSYCH_SVC_NAME=
AI_GATEWAY_SVC_NAME=

# -----------------------------------------------------------------------------
# Application environment label (e.g. local, dev, staging, prod)
# -----------------------------------------------------------------------------
APP_ENVIRONMENT=

# -----------------------------------------------------------------------------
# Downstream service URIs (used by api-gateway routing)
# -----------------------------------------------------------------------------
AUTH_SVC_URI=
PARENT_SVC_URI=
CENTER_SVC_URI=
ASSESS_SVC_URI=
PSYCH_SVC_URI=
AI_GATEWAY_SVC_URI=
AI_GATEWAY_BASE_URL=
JWT_JWKS_URI=
JWT_ISSUER=

# -----------------------------------------------------------------------------
# HikariCP connection pool (per service — same variable pattern)
# -----------------------------------------------------------------------------
AUTH_SVC_DB_POOL_MAX_SIZE=
AUTH_SVC_DB_POOL_MIN_IDLE=
AUTH_SVC_DB_CONNECTION_TIMEOUT_MS=
AUTH_SVC_DB_IDLE_TIMEOUT_MS=
PARENT_SVC_DB_POOL_MAX_SIZE=
PARENT_SVC_DB_POOL_MIN_IDLE=
PARENT_SVC_DB_CONNECTION_TIMEOUT_MS=
PARENT_SVC_DB_IDLE_TIMEOUT_MS=
CENTER_SVC_DB_POOL_MAX_SIZE=
CENTER_SVC_DB_POOL_MIN_IDLE=
CENTER_SVC_DB_CONNECTION_TIMEOUT_MS=
CENTER_SVC_DB_IDLE_TIMEOUT_MS=
ASSESS_SVC_DB_POOL_MAX_SIZE=
ASSESS_SVC_DB_POOL_MIN_IDLE=
ASSESS_SVC_DB_CONNECTION_TIMEOUT_MS=
ASSESS_SVC_DB_IDLE_TIMEOUT_MS=
PSYCH_SVC_DB_POOL_MAX_SIZE=
PSYCH_SVC_DB_POOL_MIN_IDLE=
PSYCH_SVC_DB_CONNECTION_TIMEOUT_MS=
PSYCH_SVC_DB_IDLE_TIMEOUT_MS=

# -----------------------------------------------------------------------------
# Kafka topic names
# -----------------------------------------------------------------------------
KAFKA_TOPIC_AUTH_EVENTS=
KAFKA_TOPIC_AUDIT_IMMUTABLE=
KAFKA_TOPIC_NOTIFICATION_SEND=
KAFKA_TOPIC_PSYCH_EVENTS=
KAFKA_TOPIC_ASSESS_EVENTS=
KAFKA_TOPIC_CENTER_EVENTS=
KAFKA_TOPIC_PARENT_EVENTS=

# -----------------------------------------------------------------------------
# Kafka consumer group IDs (per service)
# -----------------------------------------------------------------------------
AUTH_SVC_KAFKA_CONSUMER_GROUP=
PARENT_SVC_KAFKA_CONSUMER_GROUP=
CENTER_SVC_KAFKA_CONSUMER_GROUP=
ASSESS_SVC_KAFKA_CONSUMER_GROUP=
PSYCH_SVC_KAFKA_CONSUMER_GROUP=
AI_GATEWAY_SVC_KAFKA_CONSUMER_GROUP=

# -----------------------------------------------------------------------------
# Resilience4j — circuit breaker + rate limiter parameters
# -----------------------------------------------------------------------------
R4J_CB_AI_WINDOW_SIZE=
R4J_CB_AI_FAILURE_THRESHOLD=
R4J_CB_AI_WAIT_DURATION=
R4J_CB_AUTH_WINDOW_SIZE=
R4J_CB_AUTH_FAILURE_THRESHOLD=
R4J_CB_AUTH_WAIT_DURATION=
R4J_CB_CAPTCHA_WINDOW_SIZE=
R4J_CB_CAPTCHA_FAILURE_THRESHOLD=
R4J_CB_CAPTCHA_WAIT_DURATION=
R4J_TL_AI_TIMEOUT=
R4J_RL_LOGIN_LIMIT=
R4J_RL_LOGIN_REFRESH_PERIOD=
R4J_RL_LOGIN_TIMEOUT=

# -----------------------------------------------------------------------------
# API Gateway rate limiter
# -----------------------------------------------------------------------------
GATEWAY_RATE_LIMIT_REPLENISH_RATE=
GATEWAY_RATE_LIMIT_BURST_CAPACITY=
GATEWAY_RATE_LIMIT_REQUESTED_TOKENS=

# -----------------------------------------------------------------------------
# Kafka Docker container configuration
# -----------------------------------------------------------------------------
KAFKA_NODE_ID=
KAFKA_CONTROLLER_QUORUM_VOTERS=
KAFKA_EXTERNAL_PORT=
KAFKA_AUTO_CREATE_TOPICS=
KAFKA_DEFAULT_PARTITIONS=
KAFKA_DEFAULT_REPLICATION_FACTOR=
KAFKA_LOG_RETENTION_HOURS=

# -----------------------------------------------------------------------------
# Redis TLS
# -----------------------------------------------------------------------------
REDIS_SSL_ENABLED=

# -----------------------------------------------------------------------------
# Kafka UI (dev only)
# -----------------------------------------------------------------------------
KAFKA_UI_PORT=
KAFKA_UI_CLUSTER_NAME=

# -----------------------------------------------------------------------------
# pgAdmin (dev only)
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=
PGADMIN_PASSWORD=
PGADMIN_PORT=

# -----------------------------------------------------------------------------
# Redis Commander (dev only)
# -----------------------------------------------------------------------------
REDIS_COMMANDER_PORT=

# -----------------------------------------------------------------------------
# Anthropic base URL (in case of proxy / custom endpoint)
# -----------------------------------------------------------------------------
ANTHROPIC_BASE_URL=

# -----------------------------------------------------------------------------
# Python AI sidecar timeouts
# -----------------------------------------------------------------------------
PSYCH_AI_SVC_CONNECT_TIMEOUT_SECONDS=
PSYCH_AI_SVC_READ_TIMEOUT_SECONDS=

# -----------------------------------------------------------------------------
# CAT (Computer Adaptive Testing) engine
# -----------------------------------------------------------------------------
CAT_MIN_QUESTIONS=
CAT_MAX_QUESTIONS=
CAT_INITIAL_THETA=
CAT_CONVERGENCE_THRESHOLD=

# -----------------------------------------------------------------------------
# assess-svc WebSocket relay (STOMP)
# -----------------------------------------------------------------------------
ASSESS_SVC_WS_DESTINATION_PREFIX=
ASSESS_SVC_WS_RELAY_HOST=
ASSESS_SVC_WS_RELAY_PORT=

# -----------------------------------------------------------------------------
# EduPath services (student-gateway cluster)
# -----------------------------------------------------------------------------
STUDENT_GATEWAY_PORT=8089

# student-profile-svc
STUDENT_PROFILE_SVC_PORT=8090
STUDENT_PROFILE_DB_NAME=
STUDENT_PROFILE_DB_USER=
STUDENT_PROFILE_DB_PASSWORD=

# exam-tracker-svc
EXAM_TRACKER_SVC_PORT=8091
EXAM_TRACKER_DB_NAME=
EXAM_TRACKER_DB_USER=
EXAM_TRACKER_DB_PASSWORD=
EXAM_TRACKER_SVC_DB_POOL_MAX_SIZE=10

# performance-svc
PERFORMANCE_SVC_PORT=8092
PERFORMANCE_DB_NAME=
PERFORMANCE_DB_USER=
PERFORMANCE_DB_PASSWORD=
PYTHON_AI_SVC_BASE_URL=http://python-ai-svc:8090

# ai-mentor-svc
AI_MENTOR_SVC_PORT=8086
AI_MENTOR_DB_NAME=
AI_MENTOR_DB_USER=
AI_MENTOR_DB_PASSWORD=
KAFKA_TOPIC_AI_MENTOR_STUDY_PLAN_CREATED=
KAFKA_TOPIC_AI_MENTOR_DOUBT_SUBMITTED=
KAFKA_TOPIC_AI_MENTOR_DOUBT_RESOLVED=

# career-oracle-svc
CAREER_ORACLE_SVC_PORT=8087
CAREER_ORACLE_DB_NAME=
CAREER_ORACLE_DB_USER=
CAREER_ORACLE_DB_PASSWORD=
KAFKA_TOPIC_CAREER_ORACLE_RECOMMENDED=
KAFKA_TOPIC_CAREER_ORACLE_PROFILE_CREATED=

# mentor-svc
MENTOR_SVC_PORT=8088
MENTOR_DB_NAME=
MENTOR_DB_USER=
MENTOR_DB_PASSWORD=
KAFKA_TOPIC_MENTOR_SESSION_BOOKED=
KAFKA_TOPIC_MENTOR_SESSION_COMPLETED=
KAFKA_TOPIC_MENTOR_SESSION_FEEDBACK=

# EduPath downstream service URIs (used by student-gateway routing)
STUDENT_PROFILE_SVC_URI=
EXAM_TRACKER_SVC_URI=
PERFORMANCE_SVC_URI=
AI_MENTOR_SVC_URI=
CAREER_ORACLE_SVC_URI=
MENTOR_SVC_URI=

# -----------------------------------------------------------------------------
# gRPC Ports (each service exposes HTTP + gRPC simultaneously)
# -----------------------------------------------------------------------------
ASSESS_SVC_GRPC_PORT=9092
PERFORMANCE_SVC_GRPC_PORT=9094
AI_MENTOR_SVC_GRPC_PORT=9096
CAREER_ORACLE_SVC_GRPC_PORT=9097
MENTOR_SVC_GRPC_PORT=9098
